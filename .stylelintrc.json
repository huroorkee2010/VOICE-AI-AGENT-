{
  "extends": [
    "stylelint-config-standard"
  ],
  "rules": {
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": [
          "tailwind",
          "apply",
          "layer",
          "responsive",
          "screen",
          "variants"
        ]
      }
    ],
    "declaration-no-important": null,
    "selector-class-pattern": null,
    "color-no-invalid-hex": null,
    "unit-allowed-list": [
      "%",
      "deg",
      "ms",
      "px",
      "rem",
      "s",
      "vh",
      "vw",
      "em"
    ]
  }
}
