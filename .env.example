################################################################################
# HUVOICE AI - Environment Configuration
# Copy this file to .env.local and fill in your actual API keys
# NEVER commit .env.local to version control - add to .gitignore
################################################################################

################################################################################
# REQUIRED: OpenAI Configuration (AI responses)
################################################################################
# Get your API key from: https://platform.openai.com/api-keys
# Required for: AI text generation and response processing
# Cost: Pay-as-you-go, monitor usage at https://platform.openai.com/account/billing
OPENAI_API_KEY=sk-your-actual-key-here

################################################################################
# REQUIRED: ElevenLabs Configuration (Natural voice synthesis)
################################################################################
# Get your API key from: https://elevenlabs.io (free tier available)
# Required for: Converting AI text responses to natural-sounding audio
# Default voice: Bella (21m00Tcm4TlvDq8ikWAM)
# Try other voices: https://elevenlabs.io/docs/voices
ELEVENLABS_API_KEY=your-actual-key-here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

################################################################################
# OPTIONAL: Deepgram Configuration (Alternative speech-to-text)
################################################################################
# Get your API key from: https://console.deepgram.com (free tier available)
# Optional for: High-quality speech transcription (alternative to browser Web Speech API)
# If not set, app uses browser's Web Speech API
# Cost: Deepgram charges per minute of audio transcribed
DEEPGRAM_API_KEY=your-key-here

################################################################################
# OPTIONAL: n8n Webhook Integration (AI backend automation)
################################################################################
# This is your n8n workflow webhook URL for custom AI processing
# If not set, app uses direct OpenAI API calls
# Set up n8n at: https://n8n.io
AI_WEBHOOK_URL=https://your-domain.app.n8n.cloud/webhook/your-workflow-name

################################################################################
# Application Configuration
################################################################################
# App name displayed in UI
NEXT_PUBLIC_APP_NAME=HUVOICE AI

# API base URL - relative path for same-domain requests (production)
# Use /api for production, http://localhost:3000/api for cross-domain dev
NEXT_PUBLIC_API_BASE_URL=/api

################################################################################
# Feature Flags (NEXT_PUBLIC_* are exposed to frontend, safe to set)
################################################################################
# Enable ElevenLabs for natural voice (set to false to disable)
NEXT_PUBLIC_USE_ELEVENLABS=true

# Enable Deepgram for speech-to-text (set to false to use Web Speech API)
NEXT_PUBLIC_USE_DEEPGRAM=false

# Enable OpenAI Realtime API (experimental)
NEXT_PUBLIC_USE_OPENAI_REALTIME=true

################################################################################
# Debug & Development
################################################################################
# Enable verbose logging in console (frontend and server)
# Set to false in production
NEXT_PUBLIC_DEBUG_MODE=false
